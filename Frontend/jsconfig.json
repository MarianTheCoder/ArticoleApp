{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] },
    "module": "ESNext",
    "target": "ESNext",
    "jsx": "react",
    "checkJs": false,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0 // <--- ADD THIS. It stops VS Code from indexing inside node_modules
  },
  "exclude": ["node_modules"]
}
